# Version control
.git
.gitignore

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
coverage.json
htmlcov/

# Environment and secrets
.env
*.key
*.pem
certs/

# Databases
*.db
*.sqlite3

# Software images (NOS/firmware blobs, often 700MB-1GB+ each).
# Bind-mounted at runtime via docker-compose (./software_images ->
# /app/state/software_images); must never be baked into image layers or the
# layer export fills the container runtime's data-root.
software_images/
state/software_images/

# IDE and editor
.vscode/
.idea/
*.swp
*.swo

# CI/CD and docs
.github/
*.md
LICENSE

# Dev tooling
.pre-commit-config.yaml
mypy.ini
pytest.ini
requirements-dev.txt
check_syntax.py

# OS artifacts
Thumbs.db
.DS_Store

# Deploy scripts (not needed inside container; entrypoint is copied at build time)
deploy/*
!deploy/docker-entrypoint.sh
