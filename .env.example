# Copy to .env and set real values before running in shared or production environments.
APP_HOST=0.0.0.0
APP_PORT=8080
APP_RELOAD=false
APP_EXPOSE=false
APP_HTTPS=false
# Comma-separated allowed web origins for browser requests with credentials.
# Examples: https://plexus.example.com,https://admin.example.com
APP_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Enable HSTS header. Defaults to the value of APP_HTTPS when omitted.
APP_HSTS=true
# HSTS max-age in seconds (1 year default).
APP_HSTS_MAX_AGE=31536000
# Redirect plaintext HTTP requests to HTTPS at the app level.
# Detects scheme via X-Forwarded-Proto (reverse proxy) or request URL scheme (direct TLS).
# Defaults to the value of APP_HTTPS when omitted. /api/health is exempt for load-balancer probes.
APP_HTTPS_REDIRECT=true
# API rate limiting — per-IP sliding-window throttle for all API endpoints
# (login has its own brute-force protection separate from this).
APP_API_RATE_LIMIT_ENABLED=true
APP_API_RATE_LIMIT_WINDOW=60
APP_API_RATE_LIMIT_MAX_READ=120
APP_API_RATE_LIMIT_MAX_WRITE=40
APP_REQUIRE_API_TOKEN=false
# Optional but recommended for service-to-service API access.
APP_API_TOKEN=
# Set to true to allow public self-registration via /api/auth/register.
APP_ALLOW_SELF_REGISTER=false
# Database backend selection: sqlite (default) or postgres.
APP_DB_ENGINE=sqlite
# Used when APP_DB_ENGINE=postgres.
APP_DATABASE_URL=postgresql://plexus:plexus@postgres:5432/plexus
POSTGRES_DB=plexus
POSTGRES_USER=plexus
POSTGRES_PASSWORD=change_me
# Optional SQLite tuning for VM/shared-disk environments.
# Keep DB on low-latency local disk when possible.
APP_DB_PATH=netcontrol.db
# SQLite connect timeout in seconds.
APP_SQLITE_CONNECT_TIMEOUT=30
# SQLite lock wait timeout in milliseconds before returning 'database is locked'.
APP_SQLITE_BUSY_TIMEOUT_MS=5000
