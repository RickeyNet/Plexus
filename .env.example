# Copy to .env and set real values before running in shared or production environments.
APP_HOST=0.0.0.0
APP_PORT=8080
APP_RELOAD=false
APP_EXPOSE=false
APP_HTTPS=false
# Comma-separated allowed web origins for browser requests with credentials.
# Examples: https://plexus.example.com,https://admin.example.com
APP_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Enable HSTS header. Defaults to the value of APP_HTTPS when omitted.
APP_HSTS=true
# HSTS max-age in seconds (1 year default).
APP_HSTS_MAX_AGE=31536000
# Redirect plaintext HTTP requests to HTTPS at the app level.
# Detects scheme via X-Forwarded-Proto (reverse proxy) or request URL scheme (direct TLS).
# Defaults to the value of APP_HTTPS when omitted. /api/health is exempt for load-balancer probes.
APP_HTTPS_REDIRECT=true
# API rate limiting - per-IP sliding-window throttle for all API endpoints
# (login has its own brute-force protection separate from this).
APP_API_RATE_LIMIT_ENABLED=true
APP_API_RATE_LIMIT_WINDOW=60
APP_API_RATE_LIMIT_MAX_READ=120
APP_API_RATE_LIMIT_MAX_WRITE=40
APP_REQUIRE_API_TOKEN=false
# Optional but recommended for service-to-service API access.
APP_API_TOKEN=
# Set to true to allow public self-registration via /api/auth/register.
APP_ALLOW_SELF_REGISTER=false
# Database backend selection: sqlite (default) or postgres.
APP_DB_ENGINE=sqlite
# Used when APP_DB_ENGINE=postgres.
APP_DATABASE_URL=postgresql://plexus:plexus@postgres:5432/plexus
POSTGRES_DB=plexus
POSTGRES_USER=plexus
POSTGRES_PASSWORD=change_me
# Optional SQLite tuning for VM/shared-disk environments.
# Keep DB on low-latency local disk when possible.
APP_DB_PATH=netcontrol.db
# SQLite connect timeout in seconds.
APP_SQLITE_CONNECT_TIMEOUT=30
# SQLite lock wait timeout in milliseconds before returning 'database is locked'.
APP_SQLITE_BUSY_TIMEOUT_MS=5000
# Read-only SQLite connections pooled for read helpers (WAL concurrent reads).
# Each costs one worker thread; 0 disables the pool (reads then serialize
# behind the single writer connection, the pre-pool behavior).
APP_SQLITE_READ_POOL=4
# Maximum jobs that may run at once.
APP_MAX_CONCURRENT_JOBS=4
# On SIGTERM, how long to let in-flight jobs finish before the process exits
# (seconds). Keep below the container's stop_grace_period (compose: 30s).
APP_SHUTDOWN_JOB_GRACE_SECONDS=15
# Maximum devices processed concurrently inside each Python playbook job.
APP_PLAYBOOK_HOST_CONCURRENCY=5
# Fan-out cap for bulk device CLI/SSH operations (config backups, drift
# checks, compliance scans, deployments, MAC collection, risk analysis).
APP_DEVICE_OP_CONCURRENCY=4
# Job log persistence is batched so verbose jobs do not commit every line.
APP_JOB_EVENT_BATCH_SIZE=50
APP_JOB_EVENT_FLUSH_SECONDS=0.1
# NetFlow / sFlow / IPFIX collector - disabled by default. When enabled, the
# app opens a UDP listener on APP_NETFLOW_PORT for NetFlow v5 + v9/IPFIX.
# Ensure docker-compose exposes the port (already mapped: 2055/udp, 6343/udp)
# and DOCKER-USER/UFW rules permit the exporter source CIDRs - see
# deploy/DEPLOYMENT.md.
APP_NETFLOW_ENABLED=false
APP_NETFLOW_PORT=2055
APP_SFLOW_PORT=6343
# Retention for raw flow_records rows (hours). Older rows are pruned by the
# hourly aggregation cycle. Aggregated flow_summaries are retained separately.
APP_FLOW_RETENTION_HOURS=48
# How often to run the aggregation + retention cycle (seconds). Minimum 60.
APP_FLOW_AGGREGATION_INTERVAL_SECONDS=3600

# ── Security-relevant toggles ────────────────────────────────────────────────
# Expose the OpenAPI docs (/docs, /redoc, /openapi.json). Disabled by default
# so the full API schema isn't public; enable only in trusted environments.
APP_ENABLE_DOCS=false
# SSRF guard override. Empty = enforce the built-in reserved/link-local/
# loopback/metadata blocklist on all outbound requests (SIEM forwarder,
# webhooks, federation, IPAM/DHCP adapters, cloud pullers). Set to a
# comma-separated host/CIDR allowlist ONLY to permit specific internal
# targets - leaving it empty is the safe default.
APP_SSRF_ALLOW=
# Federation: require https:// for peer URLs (the peer API token is admin-
# equivalent and travels as a header). Set true only for isolated lab nets.
PLEXUS_FEDERATION_ALLOW_HTTP=false
# Max software-image upload size in MiB (matches nginx client_max_body_size).
PLEXUS_MAX_IMAGE_UPLOAD_MB=2048
# Directory for uploaded floor-plan images. In Docker, point this at the
# persistent state volume (compose sets /app/state/floor_plans) - the code
# default (<repo>/floor_plans) is lost on container recreate.
GEO_FLOOR_PLAN_DIR=

# ── First-boot admin bootstrap ───────────────────────────────────────────────
# On first boot with no users, an 'admin' account is created. Leave the
# password unset to get a random one printed once to the logs (recommended),
# or set PLEXUS_INITIAL_ADMIN_PASSWORD to choose it. PLEXUS_DEV_BOOTSTRAP
# enables the deterministic admin/netcontrol dev login and MUST stay false in
# production. PLEXUS_FORCE_ADMIN_PASSWORD_RESET forces a change at next login.
PLEXUS_INITIAL_ADMIN_USERNAME=admin
PLEXUS_INITIAL_ADMIN_PASSWORD=
PLEXUS_DEV_BOOTSTRAP=false
PLEXUS_FORCE_ADMIN_PASSWORD_RESET=false
